{
  "extends": "@logux/stylelint-config",
  "ignoreFiles": ["**/*", "!**/*.css", "!**/*.pcss", "client/dist/**/*"],
  "rules": {
    "function-disallowed-list": ["rgb", "rgba", "hsl", "hsla"],
    "alpha-value-notation": "percentage",
    "color-named": "never",
    "declaration-block-no-redundant-longhand-properties": null
  }
}
