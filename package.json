{
  "name": "browsersl.ist",
  "private": true,
  "homepage": "https://browsersl.ist/",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "pnpm -r start",
    "prebuild": "pnpm -r prebuild",
    "build": "pnpm -r build",
    "test:js": "oxlint .",
    "test:css": "stylelint .",
    "test:checks": "node scripts/check-versions.js",
    "test:audit": "pnpm audit --prod",
    "test": "pnpm run prebuild && pnpm build && pnpm run --recursive --include-workspace-root /^test:/"
  },
  "devDependencies": {
    "@logux/oxc-configs": "^0.4.1",
    "@logux/stylelint-config": "^1.0.1",
    "actions-up": "^1.16.0",
    "nano-staged": "^1.0.2",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.14.1",
    "svgo": "^4.0.2",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=26"
  },
  "packageManager": "pnpm@11.15.1"
}
