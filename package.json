{
  "name": "browsersl.ist",
  "private": true,
  "homepage": "https://browsersl.ist/",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "start": "pnpm -r start",
    "prebuild": "pnpm -r prebuild",
    "build": "pnpm -r build",
    "test:js": "eslint .",
    "test:css": "stylelint **/*.css",
    "test:checks": "node scripts/check-versions.js",
    "test:audit": "pnpm audit --prod",
    "test": "pnpm run prebuild && pnpm build && pnpm run --recursive --include-workspace-root /^test:/"
  },
  "devDependencies": {
    "@logux/eslint-config": "^57.1.0",
    "@logux/stylelint-config": "^0.22.0",
    "actions-up": "^1.12.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "nano-staged": "^0.9.0",
    "prettier": "^3.8.1",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.5.0",
    "svgo": "^4.0.1"
  }
}
